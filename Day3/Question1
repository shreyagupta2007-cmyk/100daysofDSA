#include<stdio.h>
int main()
{
    int n,k,comp=0;
    printf("Enter the size of array:");
    scanf("%d",&n);
    int arr[n];
    printf("Enter array elements:");
    for(int i=0;i<n;i++)
    {
        scanf("%d", &arr[i]);
    }
    printf("Enter key to find:");
    scanf("%d",&k);
    for(int i=0;i<n;i++)
    {
        comp++;
        if((arr[i])==k)
        {
            printf("Found at index %d\n", i);
            printf("Comparisons:%d",comp);
            break;
        }
    }
    return 0;
}
