#include<stdio.h>
int main()
{
    int x,y,z;
    printf("Enter the size of log1:");
    scanf("%d",&x);
    printf("Enter the size of log2:");
    scanf("%d",&y);
    z=x+y;
    int a[x],b[y],c[z];
    printf("Enter the elements of log1 which is already sorted in ascending order:");
    for(int i=0;i<x;i++)
    {
        scanf("%d",&a[i]);
    }
    printf("Enter the elements of log2 which is already sorted in ascending order:");
    for(int i=0;i<y;i++)
    {
        scanf("%d",&b[i]);
    }
    for(int i=0;i<x;i++)
    {
        c[i]=a[i];
    }
    for(int i=0;i<y;i++)
    {
        c[x]=b[i];
        x++;
    }
    for(int i=0;i<z-1;i++)
    {
        for(int j=i+1;j<z;j++)
        {
            if(c[i]>c[j])
            {
                int temp=c[i];
                c[i]=c[j];
                c[j]=temp;
            }
        }
    }
    printf("Output:\n");
    for(int i=0;i<z;i++)
    {
        printf("%d ",c[i]);
    }
    return 0;
}
