#include <stdio.h>
int main()
{
    int n;
    printf("Enter size of array:");
    scanf("%d", &n);
    int arr[n];
    printf("Enter array elements:");
    for(int i=0;i<n;i++)
    {
        scanf("%d", &arr[i]);
    }
    printf("Original array:");
    for(int i=0;i<n;i++)
    {
        printf("%d ", arr[i]);
    }
    int left=0;
    int right=n-1;
    while(left<right)
    {
        int temp=arr[left];
        arr[left]=arr[right];
        arr[right]=temp;
        left++;
        right--;
    }
    printf("\nReversed array:");
    for(int i=0;i<n;i++) 
    {
        printf("%d ", arr[i]);
    }
    return 0;
}
